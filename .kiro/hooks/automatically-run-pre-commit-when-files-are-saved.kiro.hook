{
  "version": "1.0.0",
  "enabled": true,
  "name": "Automatically run pre-commit when files are saved",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.tf"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "pre-commit run -a",
    "timeout": 30
  },
  "workspaceFolderName": "aws-q-academy",
  "shortName": "automatically-run-pre-commit-when-files-are-saved"
}